{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Installer window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://akoos.eu" },
        { "url": "https://www.photosforproton.eu" },
        { "url": "https://github.com/PhotosforProton/photos-desktop" },
        { "url": "https://github.com/PhotosforProton/photos-desktop/issues" },
        { "url": "mailto:github@akoos.eu" }
      ]
    }
  ]
}
