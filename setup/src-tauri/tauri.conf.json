{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photos for Proton Setup",
  "version": "0.2.0-beta.1",
  "identifier": "eu.akoos.photos.setup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Photos for Proton Setup",
        "width": 560,
        "height": 560,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": ["icons/icon.ico"]
  }
}
